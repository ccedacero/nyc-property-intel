# PostgreSQL connection string
DATABASE_URL=postgresql://nycdb:nycdb@localhost:5432/nycdb

# NYC GeoClient API v2 (preferred: subscription key)
# Register at https://api-portal.nyc.gov/
NYC_GEOCLIENT_SUBSCRIPTION_KEY=

# Legacy GeoClient auth (used if subscription key is not set)
NYC_GEOCLIENT_APP_ID=
NYC_GEOCLIENT_APP_KEY=

# Socrata Open Data API token
# Register at https://data.cityofnewyork.us/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

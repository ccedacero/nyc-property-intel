# PostgreSQL connection string
DATABASE_URL=postgresql://nycdb:nycdb@localhost:5432/nycdb

# NYC GeoClient API v2 (preferred: subscription key)
# Register at https://api-portal.nyc.gov/
NYC_GEOCLIENT_SUBSCRIPTION_KEY=

# Legacy GeoClient auth (used if subscription key is not set)
NYC_GEOCLIENT_APP_ID=
NYC_GEOCLIENT_APP_KEY=

# Socrata Open Data API token
# Register at https://data.cityofnewyork.us/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ── Hosted deployment (Railway / cloud) ───────────────────────────────
# Set MCP_TRANSPORT=sse to switch from local stdio to hosted SSE mode.
# PORT is set automatically by Railway; override locally if needed.
# MCP_TRANSPORT=sse
# PORT=8000

# ── Web chat ───────────────────────────────────────────────────────────
# Claude API key for web chat (Haiku 4.5)
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# HMAC secret for signing free-tier session cookies
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
COOKIE_SECRET=

# Fernet key for encrypting tokens in magic link rows
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEB_CHAT_TOKEN_KEY=

# PostgreSQL connection string
DATABASE_URL=postgresql://nyc_property:devpassword@localhost:5432/nyc_property_intel

# NYC GeoClient API (aka NYC Planning Labs Geocoder)
# Register at https://api-portal.nyc.gov/
NYC_GEOCLIENT_APP_ID=
NYC_GEOCLIENT_APP_KEY=

# Socrata Open Data API token
# Register at https://data.cityofnewyork.us/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
